# Shore Assistant — back-end environment template
# Copy to .env and uncomment/edit the values you want to override.
# All variables are optional; sensible defaults live in app/core/config.py.

# ─────── LLM (llama.cpp llama-server) ───────
# LLAMA_BASE_URL=http://localhost:8080
# LLAMA_MODEL=gemma-4-26B-A4B-it-UD-Q5_K_M
# LLAMA_TIMEOUT=120

# ─────── Persona ───────
# PERSONA=kuudere    # "base" or "kuudere"

# ─────── Short-term memory (Phase 1, Redis on LAN DB server) ───────
# REDIS_URL=redis://192.168.1.50:6379/0
# REDIS_SHORT_TERM_KEY=shore:short_term:messages
# MEMORY_MAX_TURNS=15

# ─────── Profile + Episodic (Phase 2, declared early) ───────
# POSTGRES_URL=postgresql://shore:CHANGEME@192.168.1.50:5432/shore_memory
# QDRANT_URL=http://192.168.1.50:6333

# ─────── STT (Whisper) ───────
# STT_ENABLED=False

# ─────── Remote AI machine hardware probe over SSH ───────
# REMOTE_SERVER_ENABLED=True
# REMOTE_SERVER_NAME=Tranh
# REMOTE_SERVER_SSH_ENABLED=True
# REMOTE_SERVER_SSH_HOST=192.168.1.211
# REMOTE_SERVER_SSH_USER=monitor
# REMOTE_SERVER_SSH_KEY_PATH=/home/luna/.ssh/ai_monitor_key
# REMOTE_SERVER_SSH_TIMEOUT_SECONDS=5

# ─────── Terminal backend (shore-pty-service) ───────
# TERMINAL_DEFAULT_SHELL=powershell
# TERMINAL_DEFAULT_CWD=

# Node PTY microservice (shore-pty-service)
# NODE_PTY_WS_URL=wss://terminal.shore-keeper.com
# NODE_PTY_AUTH_TOKEN=            # MUST match shore-pty-service PTY_AUTH_TOKEN
# NODE_PTY_PING_INTERVAL_SECONDS=30
# NODE_PTY_PING_TIMEOUT_SECONDS=5
# NODE_PTY_RECONNECT_BASE_MS=1000
# NODE_PTY_RECONNECT_MAX_MS=30000

# Local dev override (skips the reverse proxy + DNS):
# NODE_PTY_WS_URL=ws://127.0.0.1:9100

# ─────── n8n integration (opt-in) ───────
# N8N_ENABLED=False
# N8N_BASE_URL=http://localhost:5678
# N8N_API_KEY=
# N8N_WEBHOOK_SECRET=
# N8N_REFRESH_INTERVAL_MINUTES=0

# ─────── Screen Co-pilot ───────
# COPILOT_CAPTURE_INTERVAL_SECONDS=4
# COPILOT_CHANGE_THRESHOLD=0.06
# COPILOT_COOLDOWN_SECONDS=45
# COPILOT_MAX_IMAGE_SIZE=1280

# ─────── Cloud AI sub-agents (optional) ───────
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# CLOUD_MAX_TOKENS=4096
# CLOUD_HISTORY_MAX_TURNS=10
