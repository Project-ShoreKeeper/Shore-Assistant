# LAN-facing IP of the server (set on the box, e.g. 192.168.1.50)
LAN_BIND_IP=192.168.1.X

# Postgres password (P1 does not use Postgres but the image requires it)
POSTGRES_PASSWORD=changeme

# ── Optional host-port overrides ─────────────────────────────────────
# Uncomment if the defaults (6379 / 5432 / 6333 / 6334) collide with
# another stack on the same server (e.g. an n8n bundle that already
# binds 6379 + 5432). Container-internal ports stay 6379/5432/6333/6334.
# REDIS_HOST_PORT=16379
# POSTGRES_HOST_PORT=15432
# QDRANT_REST_PORT=16333
# QDRANT_GRPC_PORT=16334
