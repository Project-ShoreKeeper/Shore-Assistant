{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Shore Assistant",
  "version": "0.1.0",
  "identifier": "com.shore-keeper.assistant",
  "build": {
    "beforeBuildCommand": {
      "cwd": "../../front-end",
      "script": "VITE_API_URL=https://api.shore-keeper.com VITE_WS_URL=wss://conv.shore-keeper.com npm run build"
    },
    "frontendDist": "../../front-end/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Shore Assistant",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["shore-assistant"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE5MDZCOEZFQkE2NUY5QjQKUldTMCtXVzYvcmdHcWNMUEFid1FPQzE1YjJ3NlNSOGoyYUFmcHZ2b09tVjBLNWVjakttNjFpWE8K",
      "endpoints": [
        "https://github.com/Project-ShoreKeeper/Shore-Assistant/releases/latest/download/latest.json"
      ]
    }
  }
}
