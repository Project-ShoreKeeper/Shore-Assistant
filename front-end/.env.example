# Frontend environment variables

# HTTP URL for the FastAPI backend (used for REST APIs)
# Example for local development: http://localhost:8000
# Example for production: https://api.shore-keeper.com
VITE_API_URL=http://localhost:8000

# WebSocket URL for the FastAPI backend (used for STT, Chat, etc.)
# Example for local development: ws://localhost:8000
# Example for production: wss://api.shore-keeper.com
VITE_WS_URL=ws://localhost:8000
